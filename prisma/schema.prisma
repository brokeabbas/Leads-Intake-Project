generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Lead {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  website           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyDomain     String?
  companyName       String?
  companySize       String?
  industry          String?
  country           String?

  emailStatus       String?
  domainEmailCount  Int?

  enrichmentError   String?

  score             Int      @default(0)
  qualified         Boolean  @default(false)
}
